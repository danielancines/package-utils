<Window x:Class="Utils.SampleProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Utils.SampleProject"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.DataContext>
        <local:MainWindowViewModel/>
    </Window.DataContext>
    <Grid>
        <Button Content="Observable Command" 
                HorizontalAlignment="Left" 
                Margin="10,10,0,0" 
                VerticalAlignment="Top"
                Command="{Binding ClickMeCommand, Mode=OneTime}"/>
        <Button Content="Generic Observable Command" 
                HorizontalAlignment="Left" 
                Margin="10,35,0,0" 
                VerticalAlignment="Top"
                Command="{Binding GenericObservableCommand, Mode=OneTime}"
                CommandParameter="{Binding Text, Source={x:Reference GenericObservableParameterTextbox}}"/>
        <TextBox x:Name="GenericObservableParameterTextbox" 
                 HorizontalAlignment="Left" 
                 Margin="188,36,0,0" 
                 TextWrapping="Wrap" 
                 Text="Generic ObservableCommand Parameter" 
                 VerticalAlignment="Top" 
                 Width="245"/>

    </Grid>
</Window>
